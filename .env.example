# Root env example
# Copy to .env and fill values

# Database (used by docker-compose as well)
DB_PASSWORD=change_me_secure_password
DATABASE_URL=postgresql+asyncpg://smailstore_user:${DB_PASSWORD}@db:5432/smailstore

# App
APP_ENV=development
SECRET_KEY=change_me_random_secret_key
CORS_ORIGINS=http://localhost:3000,https://smailstore.shop

# Meta / Facebook CAPI
META_PIXEL_ID=your_meta_pixel_id
META_ACCESS_TOKEN=your_meta_system_user_access_token
# Remove or comment out in production:
META_TEST_EVENT_CODE=TEST12345

# TikTok Events API
TIKTOK_PIXEL_CODE=your_tiktok_pixel_code
TIKTOK_ACCESS_TOKEN=your_tiktok_system_user_access_token

# Snapchat Conversions API
SNAPCHAT_PIXEL_ID=your_snapchat_pixel_id
SNAPCHAT_ACCESS_TOKEN=your_snapchat_conversions_api_token

# Google Sheets Webhook
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Next.js Public (frontend only)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_META_PIXEL_ID=your_meta_pixel_id
NEXT_PUBLIC_TIKTOK_PIXEL_CODE=your_tiktok_pixel_code
NEXT_PUBLIC_SNAPCHAT_PIXEL_ID=your_snapchat_pixel_id
NEXT_PUBLIC_SITE_URL=http://localhost:3000
